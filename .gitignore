# 编译输出目录
/unpackage/dist/*

# 依赖包
/node_modules

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# HBuilderX 配置文件
/.hbuilderx

# IDE 配置文件
.idea
.vscode

# macOS 系统文件
.DS_Store

# 临时文件
*.swp
